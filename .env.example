# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Postgres Primary (WRITE database) ----
# Used directly by the migration CLI (DDL runs better outside a pooler).
POSTGRES_PRIMARY_HOST=postgres-primary
POSTGRES_PRIMARY_PORT=5432
POSTGRES_DB=system_design_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme_password

# ---- Postgres Replica (READ database, direct) ----
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_REPLICA_PORT=5432

# ---- Pooled connections the running app actually uses ----
# Point at PgBouncer, not at Postgres directly - see docker-compose.yml.
APP_DB_WRITE_HOST=pgbouncer-primary
APP_DB_WRITE_PORT=6432
APP_DB_READ_HOST=pgbouncer-replica
APP_DB_READ_PORT=6432

# ---- Postgres replication internals ----
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=changeme_replication_password

# ---- RabbitMQ (message queue) ----
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=tasks_queue
RABBITMQ_MANAGEMENT_PORT=15672

# ---- Auth ----
JWT_SECRET=changeme_jwt_secret

# ---- Admin seed (npm run seed:admin, see app/src/database/seed-admin.ts) ----
# Bootstraps the one account needed to log in before any other users exist.
# Idempotent - safe to run more than once.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_password

# ---- Client (Next.js BFF) ----
# Internal, server-to-server only. The Next server (inside the `client`
# container) calls the Nest API directly over the docker network via
# this URL - bypassing nginx and TLS entirely, so it never has to trust
# nginx's self-signed cert. Browser-side code never sees this; it only
# ever navigates same-origin pages or submits forms to Server Actions.
# `nestjs-backend` is a network alias shared by app1 and app2 (see
# docker-compose.yml), so this round-robins across both instances the
# same way nginx's upstream does for external traffic.
INTERNAL_API_URL=http://nestjs-backend:3000

# Name of the httpOnly cookie storing the raw JWT returned by
# POST /auth/login. Never read by client-side JS.
SESSION_COOKIE_NAME=session_token

# Must match the Nest API's JwtModule signOptions.expiresIn (see
# app/src/auth/auth.module.ts, currently "1h" = 3600s) so the cookie's
# Max-Age tracks the JWT's actual expiry. If you change one, change
# the other.
SESSION_COOKIE_MAX_AGE_SECONDS=3600

# ---- CI/CD (set these as GitHub Actions secrets, not here) ----
DOCKER_REGISTRY=ghcr.io/your-username
DOCKER_USERNAME=changeme
DOCKER_PASSWORD=changeme
DEPLOY_HOST=changeme.example.com
DEPLOY_SSH_KEY=changeme
