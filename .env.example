# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Postgres Primary (WRITE database) ----
# Used directly by the migration CLI (DDL runs better outside a pooler).
POSTGRES_PRIMARY_HOST=postgres-primary
POSTGRES_PRIMARY_PORT=5432
POSTGRES_DB=system_design_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme_password

# ---- Postgres Replica (READ database, direct) ----
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_REPLICA_PORT=5432

# ---- Pooled connections the running app actually uses ----
# Point at PgBouncer, not at Postgres directly - see docker-compose.yml.
APP_DB_WRITE_HOST=pgbouncer-primary
APP_DB_WRITE_PORT=6432
APP_DB_READ_HOST=pgbouncer-replica
APP_DB_READ_PORT=6432

# ---- Postgres replication internals ----
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=changeme_replication_password

# ---- RabbitMQ (message queue) ----
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=tasks_queue
RABBITMQ_MANAGEMENT_PORT=15672

# ---- Misc / room to grow (auth, etc.) ----
JWT_SECRET=changeme_jwt_secret

# ---- Auth (demo single-credential login - see auth/auth.service.ts) ----
AUTH_USERNAME=admin
# bcrypt hash of the real password - generate with:
#   node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
AUTH_PASSWORD_HASH=changeme_bcrypt_hash

# ---- CI/CD (set these as GitHub Actions secrets, not here) ----
DOCKER_REGISTRY=ghcr.io/your-username
DOCKER_USERNAME=changeme
DOCKER_PASSWORD=changeme
DEPLOY_HOST=changeme.example.com
DEPLOY_SSH_KEY=changeme
